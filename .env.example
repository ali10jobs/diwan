# Vercel AI Gateway — required for /api/agent (Phase 7+).
# Create at: https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# Model routed through the Gateway. Defaults to a cheap tier for demo.
AI_MODEL_ID=anthropic/claude-haiku-4-5

# Deterministic fixture seed — do NOT change without a commit updating snapshots.
DIWAN_SEED=20260423

# Agent endpoint rate ceiling (requests per minute per IP).
DIWAN_RATE_LIMIT_PER_MIN=20

# Agent daily token budget (model I/O combined).
DIWAN_DAILY_TOKEN_CAP=500000
